}

.order-number-text {
    font-weight: 600;
    font-size: 1rem;
    color: var(--primary) !important;
    margin-bottom: 30px !important;
}

/* --- Toast Notifications --- */
.toast-container {
    position: fixed;
    bottom: 30px;
    left: 30px;
    z-index: 3000;
    display: flex;
    flex-direction: column;
    gap: 12px;
    pointer-events: none;
}

.toast {
    background: rgba(10, 11, 14, 0.8);
    backdrop-filter: var(--blur-normal);
    -webkit-backdrop-filter: var(--blur-normal);
    border: 1px solid rgba(165, 243, 252, 0.2);
    color: white;
    padding: 12px 24px;
    border-radius: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    transform: translateY(20px);
    opacity: 0;
    animation: toastIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    pointer-events: auto;
}

.toast i {
    color: var(--primary);
    font-size: 1rem;
}

@keyframes toastIn {
    to { transform: translateY(0); opacity: 1; }
}

.toast.toast-fade-out {
    animation: toastOut 0.4s ease-in forwards;
}

@keyframes toastOut {
    to { transform: translateY(-20px); opacity: 0; }
}

/* --- Helper Utilities --- */
.text-center { text-align: center; }
.w-100 { width: 100%; }

/* --- Responsive Media Queries --- */

/* Tablet (Screens < 1024px) */
@media (max-width: 1024px) {
    .hero-section {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 40px;
        padding-top: 120px;
        padding-bottom: 40px;
    }
    
    .hero-content {
        align-items: center;
    }
    
    .hero-actions {
        justify-content: center;
    }
    
    .hero-glass-display {
        max-width: 480px;
    }
    
    .modal-body-grid {
        grid-template-columns: 1fr;
    }
    
    .modal-img-wrapper {
        aspect-ratio: 16/9;
    }
    
    .modal-details {
        padding: 35px;
    }
    
    .footer-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* Mobile (Screens < 768px) */
@media (max-width: 768px) {
    .main-header {
        top: 10px;
        width: 95%;
    }
    
    .nav-menu {
        display: none;
    }
    
    .hero-title {
        font-size: 2.5rem;
    }
    
    .features-section, .catalog-section, .newsletter-section {
        padding: 60px 20px;
    }
    
    .newsletter-card {
        padding: 50px 20px;
    }
    
    .footer-grid {
        grid-template-columns: 1fr;
        gap: 30px;
    }
    
    .cart-drawer {
        max-width: 100%;
    }
}

/* --- Converted Amazon Products Glass styling --- */
.product-card[data-id^="B0"] .product-img {
    filter: saturate(1.15) contrast(1.1) brightness(0.85) hue-rotate(8deg) drop-shadow(0 0 10px rgba(165, 243, 252, 0.15));
    mix-blend-mode: screen; /* Fuses the garment with dark background colors */
    opacity: 0.9;
}

.product-card[data-id^="B0"] .product-img-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(165, 243, 252, 0.08) 0%, rgba(216, 180, 254, 0.08) 100%);
    mix-blend-mode: color;
    pointer-events: none;
    z-index: 2;
}

/* Hover reflection card highlight enhancement */
.product-card[data-id^="B0"]:hover .product-img {
    filter: saturate(1.2) contrast(1.1) brightness(0.95) hue-rotate(8deg) drop-shadow(0 0 15px rgba(165, 243, 252, 0.3));
    opacity: 1;
}


