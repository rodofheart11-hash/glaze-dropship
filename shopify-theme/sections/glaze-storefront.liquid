    margin-bottom: 25px;
    font-weight: 300;
    line-height: 1.6;
}

.specs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-bottom: 25px;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--border-glass);
    border-radius: 0;
    padding: 15px;
}

.spec-item {
    display: flex;
    flex-direction: column;
}

.spec-label {
