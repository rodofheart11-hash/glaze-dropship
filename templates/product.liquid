<style>
  /* ==========================================================================
   GLAZE Clothing - Architectural Fashion Styling System
   ========================================================================== */

/* --- Custom Properties & Theme Setup --- */
:root {
    /* Muted Luxury Dark Palette */
    --bg-dark: #0a0b0e;
    --bg-studio-grid: rgba(255, 255, 255, 0.015);
    --bg-glass-card: rgba(255, 255, 255, 0.02);
    --border-glass: rgba(255, 255, 255, 0.06);
    --border-glass-active: rgba(255, 255, 255, 0.15);
    
    /* Muted Liquid Glass Accents (Low Saturation Ice Blue & Soft Lavender) */
    --primary: #a5f3fc;     /* Translucent Ice Cyan */
    --secondary: #d8b4fe;   /* Muted Lavender */
    --accent: #475569;      /* Architectural Slate */
    
    --text-main: #f8fafc;   /* Pristine Off-White */
    --text-muted: #94a3b8;  /* Slate Cool Grey */
    --text-dark: #0f172a;
    
    /* Gradients */
    --gradient-primary: linear-gradient(135deg, #a5f3fc 0%, #7dd3fc 100%);
    --gradient-lavender: linear-gradient(135deg, #e9d5ff 0%, #c084fc 100%);
    --gradient-liquid: linear-gradient(135deg, #a5f3fc 0%, #cbd5e1 50%, #d8b4fe 100%);
    --gradient-glass: linear-gradient(135deg, rgba(255, 255, 255, 0.03) 0%, rgba(255, 255, 255, 0.005) 100%);
    
    /* Typography */
    --font-heading: 'Outfit', sans-serif;
    --font-body: 'Inter', sans-serif;
    
    /* Effects */
    --blur-normal: blur(25px);
    --blur-heavy: blur(60px);
    --shadow-glass: 0 10px 40px 0 rgba(0, 0, 0, 0.6);
    --shadow-glow-cyan: 0 0 25px rgba(165, 243, 252, 0.15);
    --transition-smooth: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    --transition-bounce: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* --- Reset & Base Styles --- */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    scroll-behavior: smooth;
}

body {
    background-color: var(--bg-dark);
    color: var(--text-main);
    font-family: var(--font-body);
    min-height: 100vh;
    overflow-x: hidden;
    line-height: 1.6;
    letter-spacing: 0.2px;
}

/* --- Architectural Studio Background Grid & Spotlights --- */
.blob-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -2;
    overflow: hidden;
    /* Deep charcoal studio backdrop with linear grid overlay */
    background: 
        radial-gradient(circle at 50% 20%, #111319 0%, #060709 100%);
}

/* Structural Vertical Studio Grid Lines */
.blob-container::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
        linear-gradient(to right, var(--bg-studio-grid) 1px, transparent 1px);
    background-size: 140px 100%;
    pointer-events: none;
}

/* Subtle architectural glass partitions (horizontal tiles) */
.blob-container::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
        linear-gradient(to bottom, var(--bg-studio-grid) 1px, transparent 1px);
    background-size: 100% 140px;
    pointer-events: none;
    opacity: 0.5;
}

/* Extremely soft ambient spotlights matching the model studio lighting */
.blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
    opacity: 0.15; /* Drastically reduced for luxury fashion feel */
    mix-blend-mode: screen;
    animation: floatBlob 30s infinite ease-in-out alternate;
}

.blob-cyan {
    width: 600px;
    height: 600px;
    background: var(--primary);
    top: -15%;
    left: 15%;
    animation-duration: 25s;
}

.blob-magenta {
    width: 700px;
    height: 700px;
    background: var(--secondary);
    bottom: -20%;
    right: 10%;
    animation-duration: 35s;
    animation-delay: -8s;
}

.blob-indigo {
    width: 500px;
    height: 500px;
    background: var(--accent);
    top: 35%;
    left: 45%;
    animation-duration: 28s;
    animation-delay: -15s;
}

@keyframes floatBlob {
    0% { transform: translate(0, 0) scale(1) rotate(0deg); }
    50% { transform: translate(40px, -60px) scale(1.05) rotate(180deg); }
    100% { transform: translate(0, 0) scale(1) rotate(360deg); }
}

/* --- Glassmorphic Container Core --- */
.glass-card {
    background: var(--bg-glass-card);
    backdrop-filter: var(--blur-normal);
    -webkit-backdrop-filter: var(--blur-normal);
    border: 1px solid var(--border-glass);
    border-radius: 0; /* Boxy/Minimalist architectural look */
    box-shadow: var(--shadow-glass);
    transition: var(--transition-smooth);
}

.glass-card:hover {
    border-color: var(--border-glass-active);
    background: rgba(255, 255, 255, 0.03);
}

/* --- Header / Navigation --- */
.main-header {
    position: fixed;
    top: 25px;
    left: 50%;
    transform: translateX(-50%);
    width: 92%;
    max-width: 1400px;
    height: 65px;
    z-index: 100;
    background: rgba(10, 11, 14, 0.5);
    border-radius: 0; /* Architectural edge */
    border: 1px solid rgba(255, 255, 255, 0.05);
}

.header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 100%;
    padding: 0 40px;
}

.logo {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 700;
    letter-spacing: 4px; /* Widened for editorial brand look */
    color: var(--text-main);
    text-decoration: none;
    text-transform: uppercase;
}

.logo-accent {
    font-weight: 300;
    color: var(--primary);
}

.logo-tm {
    font-size: 0.5rem;
    vertical-align: super;
    margin-left: 2px;
    color: var(--text-muted);
}

.nav-menu {
    display: flex;
    gap: 40px;
}

.nav-link {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    transition: var(--transition-smooth);
    padding: 4px 8px;
}

.nav-link:hover, .nav-link.active {
    color: var(--primary);
}

.nav-actions {
    display: flex;
    gap: 20px;
}

.nav-btn {
    background: transparent;
    border: none;
    color: var(--text-main);
    font-size: 1rem;
    cursor: pointer;
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
}

.nav-btn:hover {
    color: var(--primary);
}

.cart-toggle-btn {
    position: relative;
}

.cart-badge {
    position: absolute;
    top: 2px;
    right: 2px;
    background: var(--primary);
    color: var(--text-dark);
    font-size: 0.65rem;
    font-weight: 700;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: scale(0);
    transition: var(--transition-bounce);
}

.cart-badge.active {
    transform: scale(1);
}

/* --- Hero Section --- */
.hero-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    min-height: 100vh;
    max-width: 1400px;
    margin: 0 auto;
    padding: 140px 40px 60px 40px;
    align-items: center;
}

.hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
}

.badge {
    padding: 6px 14px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 25px;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--border-glass);
    border-radius: 0;
}

.pulse-dot {
    width: 6px;
    height: 6px;
    background: var(--primary);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--primary);
}

.hero-title {
    font-family: var(--font-heading);
    font-size: 3.8rem;
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 25px;
    letter-spacing: -0.5px;
    text-transform: capitalize;
}

.gradient-text {
    background: var(--gradient-liquid);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.hero-subtitle {
    font-size: 1.05rem;
    color: var(--text-muted);
    margin-bottom: 40px;
    max-width: 540px;
    font-weight: 300;
}

.hero-actions {
    display: flex;
    gap: 20px;
}

/* Button UI Components */
.btn {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    padding: 14px 32px;
    border-radius: 0; /* Pure architectural angles */
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    cursor: pointer;
    transition: var(--transition-smooth);
    border: none;
}

.btn-primary {
    background: var(--text-main);
    color: var(--bg-dark);
}

.btn-primary:hover {
    background: var(--primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow-cyan);
}

.btn-secondary {
    background: transparent;
    color: var(--text-main);
    border: 1px solid var(--border-glass);
}

.btn-secondary:hover {
    background: rgba(255, 255, 255, 0.03);
    border-color: var(--border-glass-active);
    transform: translateY(-2px);
}

/* Hero Display - Glass Block Frame styling */
.hero-image-wrapper {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
}

.hero-glass-display {
    width: 100%;
    aspect-ratio: 1/1;
    max-height: 520px;
    overflow: hidden;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    border-radius: 0; /* Boxy framework */
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.7);
}

.hero-display-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.95);
    transition: var(--transition-smooth);
}

.hero-glass-display:hover .hero-display-img {
    transform: scale(1.02);
}

.glass-card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(10, 11, 14, 0.75);
    backdrop-filter: var(--blur-normal);
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: 18px;
    display: flex;
    justify-content: space-around;
    z-index: 3;
}

.overlay-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
}

.stat-num {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--primary);
}

.stat-lbl {
    font-size: 0.7rem;
    text-transform: uppercase;
    color: var(--text-muted);
    letter-spacing: 1px;
}

/* --- Features Section --- */
.features-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 40px;
}

.section-header {
    text-align: center;
    margin-bottom: 70px;
}

.section-title {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 20px;
}

.section-desc {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 300;
    max-width: 580px;
    margin: 0 auto;
}

.features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
}

.feature-card {
    padding: 50px 40px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    border-radius: 0;
    border: 1px solid var(--border-glass);
}

.feature-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
    border-color: var(--border-glass-active);
}

.feature-icon-wrapper {
    width: 50px;
    height: 50px;
    border-radius: 0;
    background: transparent;
    border: 1px solid var(--border-glass);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    color: var(--primary);
    margin-bottom: 30px;
}

.feature-card h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 15px;
}

.feature-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 300;
    line-height: 1.7;
}

/* --- Catalog Section --- */
.catalog-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 80px 40px;
}

.filter-tabs {
    display: flex;
    justify-content: center;
    max-width: 600px;
    margin: 0 auto 60px auto;
    padding: 5px;
    border-radius: 0;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--border-glass);
}

.filter-tab {
    flex: 1;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: transparent;
    border: none;
    color: var(--text-muted);
    padding: 14px;
    border-radius: 0;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.filter-tab:hover {
    color: var(--text-main);
}

.filter-tab.active {
    background: rgba(255, 255, 255, 0.04);
    color: var(--primary);
    border: 1px solid rgba(255, 255, 255, 0.08);
}

.product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 40px;
}

/* Product Card - Clean Glass Panel look */
.product-card {
    border-radius: 0;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    height: 100%;
    position: relative;
    border: 1px solid var(--border-glass);
}

.product-img-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1.15;
    overflow: hidden;
    background: #0f1015;
}

.product-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.9);
    transition: var(--transition-smooth);
}

.product-card:hover .product-img {
    transform: scale(1.02);
}

.product-tag {
    position: absolute;
    top: 15px;
    left: 15px;
    background: rgba(10, 11, 14, 0.85);
    border: 1px solid var(--border-glass-active);
    color: var(--primary);
    font-size: 0.7rem;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 0;
    text-transform: uppercase;
    letter-spacing: 1px;
    z-index: 2;
}

.product-actions-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 11, 14, 0.5);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 15px;
    opacity: 0;
    transition: var(--transition-smooth);
    z-index: 2;
}

.product-card:hover .product-actions-overlay {
    opacity: 1;
}

.action-btn {
    width: 48px;
    height: 48px;
    border-radius: 0;
    background: rgba(10, 11, 14, 0.8);
    border: 1px solid var(--border-glass);
    color: white;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.action-btn:hover {
    background: var(--text-main);
    color: var(--bg-dark);
    border-color: var(--text-main);
    box-shadow: var(--shadow-glow-cyan);
}

.product-info {
    padding: 24px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
    background: rgba(10, 11, 14, 0.3);
}

.product-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.product-category {
    font-size: 0.7rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 1.5px;
}

.product-rating {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 0.75rem;
    color: var(--primary);
}

.product-name {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--text-main);
    margin-bottom: 15px;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.product-name:hover {
    color: var(--primary);
}

.product-price-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
}

.product-price {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 600;
}

.btn-add-cart {
    background: transparent;
    border: 1px solid var(--border-glass);
    color: var(--text-main);
    width: 38px;
    height: 38px;
    border-radius: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.btn-add-cart:hover {
    background: var(--text-main);
    color: var(--bg-dark);
    border-color: var(--text-main);
}

/* --- Size Selector UI --- */
.size-selector {
    display: flex;
    gap: 8px;
    margin: 15px 0;
}

.size-btn {
    width: 36px;
    height: 36px;
    border-radius: 0;
    border: 1px solid var(--border-glass);
    background: transparent;
    color: var(--text-main);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.75rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-smooth);
}

.size-btn:hover {
    border-color: var(--border-glass-active);
    background: rgba(255, 255, 255, 0.02);
}

.size-btn.active {
    background: var(--text-main);
    color: var(--bg-dark);
    border-color: var(--text-main);
}

/* --- Newsletter Section --- */
.newsletter-section {
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 40px 100px 40px;
}

.newsletter-card {
    padding: 80px 40px;
    border-radius: 0;
    text-align: center;
    background: rgba(10, 11, 14, 0.4);
    border: 1px solid var(--border-glass);
}

.newsletter-content h2 {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 15px;
}

.newsletter-content p {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 300;
    margin-bottom: 40px;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
}

.newsletter-form {
    max-width: 500px;
    margin: 0 auto;
}

.newsletter-form .input-wrapper {
    display: flex;
    padding: 4px;
    border-radius: 0;
    background: rgba(10, 11, 14, 0.7);
    border: 1px solid var(--border-glass);
}

.newsletter-form input {
    flex-grow: 1;
    background: transparent;
    border: none;
    outline: none;
    color: white;
    padding: 0 20px;
    font-size: 0.9rem;
    font-family: var(--font-body);
}

.newsletter-form input::placeholder {
    color: rgba(255, 255, 255, 0.25);
}

.btn-submit {
    background: var(--text-main);
    border: none;
    border-radius: 0;
    color: var(--bg-dark);
    font-family: var(--font-heading);
    font-weight: 600;
    padding: 12px 28px;
    cursor: pointer;
    transition: var(--transition-smooth);
    display: flex;
    align-items: center;
    gap: 8px;
}

.btn-submit:hover {
    background: var(--primary);
    box-shadow: var(--shadow-glow-cyan);
}

/* --- Footer --- */
.main-footer {
    border-radius: 0;
    border: 1px solid var(--border-glass);
    border-bottom: none;
    background: rgba(10, 11, 14, 0.6);
    padding: 80px 40px 30px 40px;
    max-width: 1400px;
    margin: 0 auto;
}

.footer-grid {
    display: grid;
    grid-template-columns: 1.5fr repeat(3, 1fr);
    gap: 40px;
    margin-bottom: 60px;
}

.footer-info p {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 300;
    margin-top: 20px;
    margin-bottom: 25px;
    max-width: 320px;
}

.social-links {
    display: flex;
    gap: 15px;
}

.social-links a {
    width: 36px;
    height: 36px;
    border-radius: 0;
    border: 1px solid var(--border-glass);
    background: transparent;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: var(--transition-smooth);
}

.social-links a:hover {
    border-color: var(--primary);
    color: var(--primary);
}

.footer-links h4 {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 25px;
}

.footer-links ul {
    list-style: none;
}

.footer-links li {
    margin-bottom: 12px;
}

.footer-links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.85rem;
    transition: var(--transition-smooth);
}

.footer-links a:hover {
    color: var(--primary);
    padding-left: 3px;
}

.footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    padding-top: 25px;
    text-align: center;
    color: rgba(255, 255, 255, 0.25);
    font-size: 0.8rem;
    letter-spacing: 0.5px;
}

/* --- Slide-Out Shopping Cart Drawer --- */
.cart-drawer-overlay {
    position: fixed;
    inset: 0;
    background: rgba(6, 7, 9, 0.7);
    backdrop-filter: blur(12px);
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: var(--transition-smooth);
}

.cart-drawer-overlay.active {
    opacity: 1;
    pointer-events: auto;
}

.cart-drawer {
    position: absolute;
    top: 0;
    right: 0;
    width: 100%;
    max-width: 460px;
    height: 100%;
    border-radius: 0;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(10, 11, 14, 0.8);
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: -10px 0 40px rgba(0, 0, 0, 0.6);
}

.cart-drawer-overlay.active .cart-drawer {
    transform: translateX(0);
}

.cart-header {
    padding: 30px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.cart-header h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
}

.close-cart-btn {
    background: transparent;
    border: none;
    color: var(--text-main);
    font-size: 1.2rem;
    cursor: pointer;
    transition: var(--transition-smooth);
}

.close-cart-btn:hover {
    color: var(--primary);
}

.cart-items {
    flex-grow: 1;
    overflow-y: auto;
    padding: 30px;
    display: flex;
    flex-direction: column;
    gap: 20px;
}

.cart-empty-message {
    text-align: center;
    margin: auto;
    color: var(--text-muted);
}

.cart-empty-message i {
    font-size: 2rem;
    color: rgba(255, 255, 255, 0.05);
    margin-bottom: 15px;
}

.cart-empty-message p {
    margin-bottom: 20px;
    font-size: 0.9rem;
}

/* Cart Item Layout */
.cart-item {
    display: flex;
    gap: 15px;
    padding-bottom: 20px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

.cart-item-img-wrapper {
    width: 75px;
    height: 85px;
    border-radius: 0;
    overflow: hidden;
    border: 1px solid var(--border-glass);
}

.cart-item-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.cart-item-info {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
}

.cart-item-name {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 500;
}

.cart-item-size {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 3px;
}

.cart-item-price {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--primary);
    margin-top: 5px;
}

.cart-item-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
}

.qty-controls {
    display: flex;
    align-items: center;
    border: 1px solid var(--border-glass);
    border-radius: 0;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
}

.qty-btn {
    background: transparent;
    border: none;
    color: white;
    width: 24px;
    height: 24px;
    cursor: pointer;
    font-size: 0.75rem;
    transition: var(--transition-smooth);
}

.qty-btn:hover {
    background: rgba(255, 255, 255, 0.03);
}

.qty-val {
    font-size: 0.8rem;
    font-weight: 600;
    width: 24px;
    text-align: center;
}

.btn-remove-item {
    background: transparent;
    border: none;
    color: rgba(255, 255, 255, 0.25);
    cursor: pointer;
    font-size: 0.85rem;
    transition: var(--transition-smooth);
}

.btn-remove-item:hover {
    color: var(--primary);
}

.cart-footer {
    padding: 30px;
    border-top: 1px solid rgba(255, 255, 255, 0.04);
    background: rgba(10, 11, 14, 0.4);
}

.cart-subtotal {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-family: var(--font-heading);
    font-size: 1.15rem;
    font-weight: 500;
    margin-bottom: 8px;
}

.cart-subtotal span:last-child {
    font-weight: 600;
    color: var(--primary);
}

.cart-shipping-notice {
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 20px;
}

.btn-checkout {
    width: 100%;
    padding: 16px;
}

.btn-checkout:disabled {
    opacity: 0.4;
    cursor: not-allowed;
    box-shadow: none;
}

/* --- Product Detail Modal --- */
.modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(6, 7, 9, 0.7);
    backdrop-filter: blur(15px);
    z-index: 2000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: var(--transition-smooth);
    padding: 20px;
}

.modal-overlay.active {
    opacity: 1;
    pointer-events: auto;
}

.modal-content {
    width: 100%;
    max-width: 900px;
    border-radius: 0; /* Architectural edge */
    overflow: hidden;
    position: relative;
    box-shadow: 0 30px 80px rgba(0, 0, 0, 0.7);
    background: rgba(10, 11, 14, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.08);
    transform: scale(0.95);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.modal-overlay.active .modal-content {
    transform: scale(1);
}

.close-modal-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    width: 36px;
    height: 36px;
    border-radius: 0;
    background: rgba(10, 11, 14, 0.8);
    border: 1px solid var(--border-glass);
    color: white;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    font-size: 1rem;
    transition: var(--transition-smooth);
    z-index: 10;
}

.close-modal-btn:hover {
    color: var(--primary);
    border-color: var(--primary);
}

.modal-body-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-height: 80vh;
}

.modal-body-grid > * {
    min-width: 0; /* Prevent image from forcing column expansion */
}

.modal-img-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
    background: #0f1015;
}

.modal-img-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.modal-details {
    padding: 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    overflow-y: auto;
    max-height: 80vh;
}

.modal-details .product-category {
    font-size: 0.75rem;
    margin-bottom: 8px;
}

.modal-product-name {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 600;
    line-height: 1.25;
    margin-bottom: 12px;
}

.modal-product-price {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--primary);
    margin-bottom: 20px;
}

.modal-product-desc {
    color: var(--text-muted);
    font-size: 0.9rem;
    margin-bottom: 25px;
    font-weight: 300;
    line-height: 1.6;
}

.specs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 15px;
    margin-bottom: 25px;
    background: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--border-glass);
    border-radius: 0;
    padding: 15px;
}

.spec-item {
    display: flex;
    flex-direction: column;
}

.spec-label {
    font-size: 0.65rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.spec-val {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-main);
}

.modal-details h4 {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 10px;
}

.modal-actions {
    display: flex;
    gap: 15px;
    margin-top: 15px;
}

.btn-add-modal {
    flex-grow: 1;
}

/* --- Checkout Success Modal --- */
.success-modal-content {
    padding: 50px;
    max-width: 480px;
    text-align: center;
    border-radius: 0;
}

.success-icon-pulse {
    font-size: 3.5rem;
    color: var(--primary);
    margin-bottom: 25px;
}

.success-modal-content h2 {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 12px;
}

.success-modal-content p {
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 300;
    margin-bottom: 15px;
}

.order-number-text {
    font-weight: 600;
    font-size: 1rem;
    color: var(--primary) !important;
    margin-bottom: 30px !important;
}

/* --- Toast Notifications --- */
.toast-container {
    position: fixed;
    bottom: 30px;
    left: 30px;
    z-index: 3000;
    display: flex;
    flex-direction: column;
    gap: 12px;
    pointer-events: none;
}

.toast {
    background: rgba(10, 11, 14, 0.8);
    backdrop-filter: var(--blur-normal);
    -webkit-backdrop-filter: var(--blur-normal);
    border: 1px solid rgba(165, 243, 252, 0.2);
    color: white;
    padding: 12px 24px;
    border-radius: 0;
    display: flex;
    align-items: center;
    gap: 12px;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.5);
    transform: translateY(20px);
    opacity: 0;
    animation: toastIn 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    pointer-events: auto;
}

.toast i {
    color: var(--primary);
    font-size: 1rem;
}

@keyframes toastIn {
    to { transform: translateY(0); opacity: 1; }
}

.toast.toast-fade-out {
    animation: toastOut 0.4s ease-in forwards;
}

@keyframes toastOut {
    to { transform: translateY(-20px); opacity: 0; }
}

/* --- Helper Utilities --- */
.text-center { text-align: center; }
.w-100 { width: 100%; }

/* --- Responsive Media Queries --- */

/* Tablet (Screens < 1024px) */
@media (max-width: 1024px) {
    .hero-section {
        grid-template-columns: 1fr;
        text-align: center;
        gap: 40px;
        padding-top: 120px;
        padding-bottom: 40px;
    }
    
    .hero-content {
        align-items: center;
    }
    
    .hero-actions {
        justify-content: center;
    }
    
    .hero-glass-display {
        max-width: 480px;
    }
    
    .modal-body-grid {
        grid-template-columns: 1fr;
    }
    
    .modal-img-wrapper {
        aspect-ratio: 16/9;
    }
    
    .modal-details {
        padding: 35px;
    }
    
    .footer-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}

/* Mobile (Screens < 768px) */
@media (max-width: 768px) {
    .main-header {
        top: 10px;
        width: 95%;
    }
    
    .nav-menu {
        display: none;
    }
    
    .hero-title {
        font-size: 2.5rem;
    }
    
    .features-section, .catalog-section, .newsletter-section {
        padding: 60px 20px;
    }
    
    .newsletter-card {
        padding: 50px 20px;
    }
    
    .footer-grid {
        grid-template-columns: 1fr;
        gap: 30px;
    }
    
    .cart-drawer {
        max-width: 100%;
    }
}

/* --- Converted Amazon Products Glass styling --- */
.product-card[data-id^="B0"] .product-img {
    filter: saturate(1.15) contrast(1.1) brightness(0.85) hue-rotate(8deg) drop-shadow(0 0 10px rgba(165, 243, 252, 0.15));
    mix-blend-mode: screen; /* Fuses the garment with dark background colors */
    opacity: 0.9;
}

.product-card[data-id^="B0"] .product-img-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(165, 243, 252, 0.08) 0%, rgba(216, 180, 254, 0.08) 100%);
    mix-blend-mode: color;
    pointer-events: none;
    z-index: 2;
}

/* Hover reflection card highlight enhancement */
.product-card[data-id^="B0"]:hover .product-img {
    filter: saturate(1.2) contrast(1.1) brightness(0.95) hue-rotate(8deg) drop-shadow(0 0 15px rgba(165, 243, 252, 0.3));
    opacity: 1;
}

